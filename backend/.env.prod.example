# Application
PROJECT_NAME=Link1Die API
PROJECT_VERSION=1.0.0
DEBUG=False
API_PORT=8000

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/link1die_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0

# JWT Security (CHANGE THIS)
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SHARE_LINK_EXPIRE_MINUTES=5

# CORS (set to your domain)
CORS_ORIGINS=["https://example.com"]

# File Storage
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=["pdf","doc","docx","txt","xlsx","csv"]
UPLOAD_DIR=/app/uploads

# Redis
REDIS_URL=redis://redis:6379/0

